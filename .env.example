# Copy to .env and set values
# GATEWAY_API_KEY=your-secret-api-key
# JWT_SECRET=your-jwt-secret-change-in-production
# REDIS_URL=redis://redis:6379/0
# ORDERS_BACKENDS=http://orders1:8001,http://orders2:8002
# LOCATIONS_BACKENDS=http://locations1:8003,http://locations2:8004
# API_KEYS=dev-api-key-12345

GATEWAY_API_KEY=dev-api-key-12345
JWT_SECRET=dev-jwt-secret-change-me
REDIS_URL=redis://redis:6379/0
ORDERS_BACKENDS=http://orders1:8001,http://orders2:8002
LOCATIONS_BACKENDS=http://locations1:8003,http://locations2:8004
API_KEYS=dev-api-key-12345
